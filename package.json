{
  "name": "@bryxen/pulse",
  "version": "0.1.2",
  "description": "Self-hosted AI gateway — OpenAI- and Anthropic-compatible, with audit logs, live dashboards, and per-token cost tracking. Powered by Bun.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/Bryxen-ai/pulse#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bryxen-ai/pulse.git"
  },
  "bugs": {
    "url": "https://github.com/Bryxen-ai/pulse/issues"
  },
  "keywords": [
    "ai",
    "gateway",
    "llm",
    "openai",
    "anthropic",
    "claude",
    "proxy",
    "self-hosted",
    "bun",
    "cli"
  ],
  "bin": {
    "pulse": "./bin/pulse"
  },
  "files": [
    "bin",
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "dev:watch": "bun --hot src/index.ts",
    "build": "bun build ./src/index.html --outdir=dist --entry-naming \"[name].[ext]\" --sourcemap --target=browser --minify",
    "build:release": "bun build ./src/index.html --outdir=dist --entry-naming \"[name].[ext]\" --target=browser --minify",
    "start": "NODE_ENV=production bun src/index.ts",
    "prepublishOnly": "bun run build:release"
  },
  "dependencies": {
    "@elysiajs/cookie": "^0.8.0",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/static": "^1.4.10",
    "elysia": "^1.4.29",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/bun": "latest"
  }
}
