#!/usr/bin/env bun
// PULSE CLI entry — invoked as `pulse <cmd>` after `bun install -g @bryxen-ai/pulse`.
// Thin shim that prepares env vars and hands control to src/index.ts.

import { parseArgs } from "node:util";
import { fileURLToPath } from "node:url";
import { createRequire } from "node:module";
import { homedir } from "node:os";
import path from "node:path";
import { existsSync, mkdirSync, readFileSync, unlinkSync, writeFileSync } from "node:fs";
import { spawnSync } from "node:child_process";

const here = path.dirname(fileURLToPath(import.meta.url));
const root = path.resolve(here, "..");
const require = createRequire(import.meta.url);
const pkg = require(path.join(root, "package.json"));

const PULSE_DIR = path.join(homedir(), ".pulse");
const PID_FILE = path.join(PULSE_DIR, "pulse.pid");

const { values, positionals } = parseArgs({
  args: process.argv.slice(2),
  allowPositionals: true,
  options: {
    port:      { type: "string",  short: "p" },
    host:      { type: "string",  short: "H" },
    "db-path": { type: "string",  short: "d" },
    auth:      { type: "boolean" },                  // opt back into login page
    help:      { type: "boolean", short: "h" },
    version:   { type: "boolean", short: "v" },
  },
});

const cmd = positionals[0] ?? (values.version ? "version" : values.help ? "help" : "run");

function usage() {
  console.log(`pulse ${pkg.version} — self-hosted AI gateway

Usage:
  pulse run [options]      Start the gateway (default)
  pulse stop               Stop a running gateway
  pulse status             Check if the gateway is running
  pulse update             Update to the latest version
  pulse version            Print version
  pulse help               Show this help

Options:
  -p, --port <n>           Listening port           (default 3000, env PORT)
  -H, --host <addr>        Bind address             (default 127.0.0.1, env HOST)
  -d, --db-path <file>     SQLite database path     (default ~/.pulse/pulse.db, env DB_PATH)
      --auth               Require login            (default off for local installs)
  -v, --version            Print version
  -h, --help               Show this help

Examples:
  pulse run
  pulse run --port 8080 --auth
  pulse run --db-path ./pulse.db
  pulse stop
  pulse status
`);
}

function ensurePulseDir() {
  if (!existsSync(PULSE_DIR)) mkdirSync(PULSE_DIR, { recursive: true });
}

function readPid(): number | null {
  try {
    const raw = readFileSync(PID_FILE, "utf-8").trim();
    const pid = parseInt(raw, 10);
    if (!pid || isNaN(pid)) return null;

    // Verify the process is still alive
    try { process.kill(pid, 0); } catch { return null; }
    return pid;
  } catch {
    return null;
  }
}

function stop() {
  const pid = readPid();
  if (!pid) {
    console.log("pulse: no running gateway found");
    process.exit(0);
  }
  console.log(`pulse: stopping gateway (pid ${pid})…`);
  try {
    process.kill(pid, "SIGTERM");
    // Wait a moment for graceful shutdown
    setTimeout(() => {
      try { process.kill(pid, 0); process.kill(pid, "SIGKILL"); } catch {}
      try { unlinkSync(PID_FILE); } catch {}
      console.log("pulse: stopped");
      process.exit(0);
    }, 2000);
  } catch {
    console.error("pulse: failed to stop gateway");
    process.exit(1);
  }
}

function status() {
  const pid = readPid();
  if (pid) {
    console.log(`pulse: running (pid ${pid})`);
  } else {
    console.log("pulse: not running");
  }
}

switch (cmd) {
  case "version":
    console.log(pkg.version);
    break;

  case "help":
    usage();
    break;

  case "status":
    status();
    break;

  case "stop":
    stop();
    break;

  case "update": {
    const pkgName = "@bryxen/pulse";
    console.log("pulse: checking for updates…");

    // 1. Fetch latest version from npm registry
    let latest: string;
    try {
      const res = await fetch(`https://registry.npmjs.org/${pkgName}/latest`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json() as { version: string };
      latest = data.version;
    } catch (e) {
      console.error("pulse: failed to check latest version");
      process.exit(1);
    }

    // 2. Compare with current version
    if (latest === pkg.version) {
      console.log(`pulse: already up to date (v${pkg.version})`);
      break;
    }

    // 3. Update — prefer bun, fall back to npm
    console.log(`pulse: updating v${pkg.version} → v${latest}…`);
    const pm = Bun.which("bun") ? "bun" : "npm";
    const args = pm === "bun"
      ? ["install", "-g", `${pkgName}@${latest}`]
      : ["install", "-g", `${pkgName}@${latest}`];
    const result = spawnSync(pm, args, { stdio: "inherit" });
    if (result.status !== 0) {
      console.error("pulse: update failed");
      process.exit(1);
    }
    console.log(`\npulse: updated to v${latest}`);
    break;
  }

  case "run":
  case "start": {
    // Prevent double-start
    const existing = readPid();
    if (existing) {
      console.error(`pulse: already running (pid ${existing}). Use "pulse stop" first.`);
      process.exit(1);
    }

    process.env.NODE_ENV   = process.env.NODE_ENV   || "production";
    process.env.PORT       = values.port            ?? process.env.PORT       ?? "3000";
    process.env.HOST       = values.host            ?? process.env.HOST       ?? "127.0.0.1";
    process.env.DB_PATH    = values["db-path"]      ?? process.env.DB_PATH    ?? path.join(homedir(), ".pulse", "pulse.db");
    if (!values.auth) process.env.PULSE_NO_AUTH = "1";

    // Write PID file
    ensurePulseDir();
    writeFileSync(PID_FILE, String(process.pid));

    // Clean up PID on exit
    const cleanup = () => { try { unlinkSync(PID_FILE); } catch {} };
    process.on("exit", cleanup);
    process.on("SIGINT", () => { cleanup(); process.exit(0); });
    process.on("SIGTERM", () => { cleanup(); process.exit(0); });

    // Hand off to the server entry. Resolved relative to this file so the
    // CLI works wherever bun's global bin happens to symlink it from.
    await import(path.join(root, "src", "index.ts"));
    break;
  }

  default:
    console.error(`pulse: unknown command "${cmd}"\n`);
    usage();
    process.exit(2);
}
